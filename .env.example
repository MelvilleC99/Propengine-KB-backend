# PropertyEngine Support Agent Configuration

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
# Rate limit tier: production (default) | dev (10k/day, local only) | strict
RATE_LIMIT_TIER=production

# Authentication: require a valid Firebase ID token on protected routes.
# Secure by default (true). Set to false ONLY for local dev or a brief migration
# window before the frontend has started sending the Authorization: Bearer token.
REQUIRE_AUTH=true

# AstraDB Configuration (Required for production)
ASTRADB_APPLICATION_TOKEN=your_astra_token_here
ASTRADB_API_ENDPOINT=https://your-database-id-region.apps.astra.datastax.com
ASTRADB_KEYSPACE=default_keyspace

# AstraDB Collection - Unified PropertyEngine Collection
ASTRADB_PROPERTY_ENGINE_COLLECTION=property_engine

# OpenAI Configuration (Required)
OPENAI_API_KEY=your_openai_api_key_here
# LLM call safety (a single call fails fast instead of hanging)
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Firebase Configuration (Optional for session management)
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_CLIENT_EMAIL=your_firebase_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# FreshDesk Configuration (Optional)
FRESHDESK_DOMAIN=your_domain.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_key
# Route AI tickets to a group queue (e.g. Customer Support). Leave unset to assign by agent only.
FRESHDESK_GROUP_ID=
# Shared secret Freshdesk must send as the X-Webhook-Secret header on the ticket-closed webhook.
FRESHDESK_WEBHOOK_SECRET=

# Development Overrides
NODE_ENV=development
